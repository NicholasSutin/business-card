---
interface Props {
  title: string;
  description: string;
  price: string;
  image?: string;
}

const { title, description, price, image } = Astro.props;
---

<div class="bg-card text-card-foreground border rounded-lg overflow-hidden flex flex-col">
  <div class="aspect-video bg-muted flex items-center justify-center">
    {image ? (
      <img src={image} alt={title} class="w-full h-full object-cover" />
    ) : (
      <span class="text-muted-foreground text-sm">Image</span>
    )}
  </div>
  <div class="p-6 space-y-2 flex-1">
    <div class="flex items-baseline justify-between gap-2">
      <h2 class="text-xl font-semibold">{title}</h2>
      <p class="text-lg font-bold shrink-0">{price}</p>
    </div>
    <p class="text-muted-foreground text-sm">{description}</p>
  </div>
  <div class="px-6 pb-6">
    <button class="inline-flex items-center justify-center rounded-md bg-primary text-primary-foreground h-10 px-4 text-sm font-medium w-full cursor-pointer hover:bg-primary/90 transition-colors">
      Add to Cart
    </button>
  </div>
</div>
